APP_PORT=6001
FRONTEND_URL=http://localhost:3000

# ── Supabase ────────────────────────────────
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── PostgreSQL (Prisma) ─────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mydb
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}?schema=public"

# ── LiveKit ─────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=http://localhost:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 (Supabase Storage for recordings) ───
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_ENDPOINT=http://localhost:8000/storage/v1/s3
SUPABASE_BUCKET_NAME=recordings

# ── AI Reports (OpenAI API) ───────────────
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_key
LLM_MODEL=gpt-4o
