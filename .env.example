# ── LiveKit ─────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WS_URL=ws://livekit:7880

# ── Supabase S3 (for egress recordings) ─────
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_ENDPOINT=http://supabase-storage:5000/storage/v1/s3
SUPABASE_BUCKET_NAME=recordings

# ── SIP (optional) ──────────────────────────
SIP_LOG_LEVEL=info
